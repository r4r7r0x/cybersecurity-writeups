#!/usr/bin/env python3

import argparse
import subprocess
import os
import json
import sys
import shutil
from datetime import datetime

# ============================
# CONFIG
# ============================

DEFAULT_WORDLIST = "/usr/share/wordlists/dirb/common.txt"

PORT_MAP = {
    21: "ftp",
    22: "ssh",
    80: "http",
    443: "http",
    445: "smb",
    139: "smb",
    3306: "mysql",
    6379: "redis",
}

SERVICE_KEYWORDS = {
    "http": "http",
    "apache": "http",
    "nginx": "http",
    "iis": "http",
    "ftp": "ftp",
    "ssh": "ssh",
    "smb": "smb",
    "microsoft-ds": "smb",
    "mysql": "mysql",
}

# ============================
# LOGGER
# ============================

RESET = "\033[0m"
BOLD = "\033[1m"
RED = "\033[91m"
GREEN = "\033[92m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
DIM = "\033[2m"

def log(msg, level="info", silent=False):
    if silent:
        return

    ts = datetime.now().strftime("%H:%M:%S")

    prefix = {
        "info": f"{CYAN}[*]{RESET}",
        "success": f"{GREEN}[+]{RESET}",
        "warn": f"{YELLOW}[!]{RESET}",
        "error": f"{RED}[-]{RESET}",
        "section": f"{BOLD}{CYAN}[>]{RESET}",
    }.get(level, "[?]")

    print(f"{DIM}{ts}{RESET} {prefix} {msg}")

# ============================
# BANNER
# ============================

def banner():
    print(f"""
{CYAN}
   ▄▄▄       ▄▄▄       ▄▄▄▄▄▄▄ ▄▄▄▄▄▄▄ ▄▄▄▄▄▄▄
  ████▄ ████ ████▄ ████ ████ ████ ████ ████ ████
  ████ ▀ ███ ████ ▀ ███ ████ ████ ████ ████ ████
  ▀▀▀▀   ▀▀▀ ▀▀▀▀   ▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀▀▀▀ ▀▀▀▀
{RESET}
   Aurora Recon Framework v4.3
   by r4r7r0x
""")

# ============================
# UTILS
# ============================

def run(cmd, timeout=120):
    try:
        res = subprocess.run(
            cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=timeout
        )
        return res.stdout, res.stderr, res.returncode
    except subprocess.TimeoutExpired:
        return "", "TIMEOUT", -1
    except Exception as e:
        return "", str(e), -1


def mkdir(path):
    os.makedirs(path, exist_ok=True)


def save(path, name, data):
    full = os.path.join(path, name)
    with open(full, "w") as f:
        f.write(data)
    return full


def tool_exists(name):
    return shutil.which(name) is not None

# ============================
# WORKSPACE
# ============================

def create_workspace(target, base):
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    safe = target.replace("/", "_").replace(":", "_")
    path = os.path.join(base, f"aurora_{safe}_{ts}")
    mkdir(path)
    return path

# ============================
# SCAN ENGINE
# ============================

def nmap_scan(target, mode, timeout):
    if mode == "fast":
        cmd = f"nmap -T4 -F -sC -sV --open {target}"
    elif mode == "full":
        cmd = f"nmap -T4 -p- -sC -sV --open {target}"
    else:
        cmd = f"nmap -T4 -sC -sV --open {target}"

    return run(cmd, timeout)

# ============================
# PARSER
# ============================

def resolve_module(port, service):
    if port in PORT_MAP:
        return PORT_MAP[port]

    for k, v in SERVICE_KEYWORDS.items():
        if k in service:
            return v

    return None


def parse_services(output):
    services = []

    for line in output.splitlines():
        if "/tcp" not in line or "open" not in line:
            continue

        parts = line.split()

        try:
            port = int(parts[0].split("/")[0])
            service = parts[2].lower()
            version = " ".join(parts[3:])
            module = resolve_module(port, service)

            services.append({
                "port": port,
                "service": service,
                "version": version,
                "module": module
            })

        except (ValueError, IndexError):
            continue

    return services

# ============================
# MODULES
# ============================

def module_http(target, port, workspace, timeout, silent, wordlist):
    scheme = "https" if port in [443, 8443] else "http"
    url = f"{scheme}://{target}:{port}"

    findings = {"url": url, "paths": []}

    if tool_exists("gobuster"):
        out, err, rc = run(
            f"gobuster dir -u {url} -w {wordlist} -q --no-error",
            timeout
        )

        if rc == 0:
            findings["paths"] = [l.strip() for l in out.splitlines() if l.strip()]

        save(workspace, f"http_{port}.txt", out)

    return findings


def module_smb(target, workspace, timeout):
    findings = {"shares": []}

    if tool_exists("enum4linux"):
        out, err, rc = run(f"enum4linux -a {target}", timeout)

        if rc == 0:
            for line in out.splitlines():
                if "Disk" in line or "IPC" in line:
                    findings["shares"].append(line.strip())

        save(workspace, "smb.txt", out)

    return findings


def module_ssh(target, port, workspace, timeout):
    out, _, _ = run(f"nc -w3 {target} {port}", timeout)
    save(workspace, f"ssh_{port}.txt", out)
    return {"banner": out.strip()}

# ============================
# DISPATCHER
# ============================

def run_modules(target, services, workspace, timeout, silent, wordlist):
    results = {}
    smb_done = False

    for s in services:
        module = s["module"]
        port = s["port"]

        if not module:
            continue

        log(f"{module.upper()} → {port}", "section", silent)

        if module == "http":
            results[f"http_{port}"] = module_http(
                target, port, workspace, timeout, silent, wordlist
            )

        elif module == "smb" and not smb_done:
            results["smb"] = module_smb(target, workspace, timeout)
            smb_done = True

        elif module == "ssh":
            results[f"ssh_{port}"] = module_ssh(target, port, workspace, timeout)

    return results

# ============================
# REPORT
# ============================

def generate_report(target, services, findings, workspace, mode, notes):
    report = {
        "tool": "Aurora v4.3",
        "target": target,
        "mode": mode,
        "timestamp": str(datetime.now()),
        "summary": {
            "ports": len(services),
            "modules": len(findings)
        },
        "services": services,
        "findings": findings,
        "loot": {
            "notes": notes if notes else [],
            "credentials": [],
            "interesting": []
        }
    }

    save(workspace, "report.json", json.dumps(report, indent=4))

# ============================
# CLI
# ============================

def get_args():
    parser = argparse.ArgumentParser(description="Aurora Recon Framework v4.3")

    parser.add_argument("-t", "--target", required=True)
    parser.add_argument("--fast", action="store_true")
    parser.add_argument("--full", action="store_true")
    parser.add_argument("--quick", action="store_true")
    parser.add_argument("--htb", action="store_true")
    parser.add_argument("--timeout", type=int, default=120)
    parser.add_argument("--silent", action="store_true")
    parser.add_argument("--notes", action="append")
    parser.add_argument("-o", "--output", default=".")

    return parser.parse_args()

# ============================
# MAIN
# ============================

def main():
    args = get_args()

    if not args.silent:
        banner()

    wordlist = DEFAULT_WORDLIST

    if args.htb:
        wordlist = "/usr/share/seclists/Discovery/Web-Content/common.txt"
        args.timeout = 60

    mode = "default"
    if args.fast or args.quick:
        mode = "fast"
    elif args.full:
        mode = "full"

    workspace = create_workspace(args.target, args.output)

    nmap_out, _, _ = nmap_scan(args.target, mode, args.timeout)
    save(workspace, "nmap.txt", nmap_out)

    services = parse_services(nmap_out)

    if not services:
        log("No open ports found", "error")
        sys.exit(1)

    findings = {}

    if not args.quick:
        findings = run_modules(
            args.target,
            services,
            workspace,
            args.timeout,
            args.silent,
            wordlist
        )

    generate_report(
        args.target,
        services,
        findings,
        workspace,
        mode,
        args.notes
    )

    log(f"Done → {workspace}", "success")


if __name__ == "__main__":
    main()